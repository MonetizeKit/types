{
  "name": "@monetizekit/types",
  "version": "0.1.0",
  "description": "Shared TypeScript types for the MonetizeKit SDK — REST/GraphQL resource shapes (Customer, Plan, PricingTerm, Subscription, EntitlementResult, UsageData, CreditBalance, …).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MonetizeKit/types.git"
  },
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "check-entry": "node scripts/check-package-entry.mjs",
    "smoke": "node scripts/install-smoke.mjs",
    "changeset": "changeset",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@eslint/js": "^9.20.0",
    "eslint": "^9.20.0",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.24.0"
  }
}
